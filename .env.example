# ==========================================================
# Print3D Manager ERP - Variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores.
# NUNCA commite o arquivo .env real.
# ==========================================================

# ----- PostgreSQL -----
POSTGRES_DB=print3d_manager
POSTGRES_USER=print3d
POSTGRES_PASSWORD=troque-esta-senha

# ----- Backend -----
SPRING_PROFILES_ACTIVE=prod
DATABASE_URL=jdbc:postgresql://postgres:5432/print3d_manager
DATABASE_USERNAME=print3d
DATABASE_PASSWORD=troque-esta-senha

# Segredo JWT: string Base64 de no mínimo 256 bits (32 bytes).
# Gere um novo com: openssl rand -base64 48
JWT_SECRET=troque-por-um-segredo-base64-de-48-bytes
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ----- CORS -----
CORS_ALLOWED_ORIGINS=http://localhost

# ----- Uploads (STL/3MF, fotos) -----
UPLOAD_DIR=/app/uploads
